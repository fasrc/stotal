#!/usr/bin/python3
# stotal is will calculate the total CPU-hours, GPU-hours, and TRES-hours for a user or account.

import sys,os,subprocess,shlex
import argparse
import time,datetime
from datetime import date

# Calculate Usage
def calc_usage(inuser, inaccount, instarttime, inendtime):

  # Get job data
  if inuser != None:
    jobdata = subprocess.Popen(['sacct','-anPXD','--units=G','--format=User,Account,Partition,Start,End,AllocTRES','-u',inuser,'-S',instarttime,'-E',inendtime],
    stdout=subprocess.PIPE,
    universal_newlines=True)
  elif inaccount != None:
    jobdata = subprocess.Popen(['sacct','-anPXD','--units=G','--format=User,Account,Partition,Start,End,AllocTRES','-A',inaccount,'-S',instarttime,'-E',inendtime],
    stdout=subprocess.PIPE,
    universal_newlines=True)

  # Converting time to integer time.
  if 'T' not in instarttime:
    instarttime=instarttime+'T00:00:00'
  if 'T' not in inendtime:
    inendtime=inendtime+'T23:59:59'
  pattern = '%Y-%m-%dT%H:%M:%S'
  instart = int(time.mktime(time.strptime(instarttime, pattern)))
  inend = int(time.mktime(time.strptime(inendtime, pattern)))
  hourrange = (inend - instart)/3600.0

  # Get Partition TRES Table
  ptresweightcpu={}
  ptresweightmem={}
  ptresweightgpu={}
  partlist = subprocess.Popen(['scontrol','-o','show','partition'], stdout=subprocess.PIPE, universal_newlines=True)
  for line in partlist.stdout:
    #Sanitize input
    line = line.replace("'", "\\'")
    
    #Turn partition information into a hash
    part = dict(s.split("=", 1) for s in shlex.split(line) if '=' in s)
    
    #Get the TRESBillingWeights for a partition
    tresweight = dict(s.split("=", 1) for s in shlex.split(part['TRESBillingWeights'].replace(",", " ")) if '=' in s)
    ptresweightcpu[part["PartitionName"]] = float(tresweight['CPU'])
    ptresweightmem[part["PartitionName"]] = float(tresweight['Mem'].strip('G'))
    if 'Gres/gpu' in tresweight:
      ptresweightgpu[part["PartitionName"]] = float(tresweight['Gres/gpu'])
    else:
      ptresweightgpu[part["PartitionName"]] = 0.0 

  cputot = 0
  memtot = 0.
  gputot = 0
  trestot = 0.

  al = {}

  cputota = {}
  memtota = {}
  gputota = {}
  trestota = {}

  cputotau = {}
  memtotau = {}
  gputotau = {}
  trestotau = {}

  # Iterate over the jobs
  for job in jobdata.stdout:
    (user,account,partition,start,end,alloctres) = job.strip().split('|')
    
    # Ignore jobs that have no allocation. That means they have never run.
    if alloctres != "":
      # Converting time to integer time.
      if end == "Unknown":
        end = inendtime
      pattern = '%Y-%m-%dT%H:%M:%S'
      start = int(time.mktime(time.strptime(start, pattern)))
      end = int(time.mktime(time.strptime(end, pattern)))
      
      # Check if job actual ran in window.
      if start < inend:
        # Storing dummy variable to get account list.
        al[account] = 1

        # Parsing AllocTRES.
        atres = dict(s.split("=", 1) for s in shlex.split(alloctres.replace(",", " ")) if '=' in s)
        cpu = int(atres["cpu"])
        mem = float(atres["mem"].strip("G"))
        if 'gres/gpu' in atres:
          gpu = int(atres['gres/gpu'])
        else:
          gpu = 0

        # Sum up the usage
        # Note that this caps the usage only in the window that is specified. The jobs may continue running before and after the window, but we care about the usage in the specific window.
        elapsedwindow = (min(end,inend)-max(start,instart))/(3600.0)

        try:
          try:
            cputotau[account][user] = cputotau[account][user]+cpu*elapsedwindow
            memtotau[account][user] = memtotau[account][user]+mem*elapsedwindow
            gputotau[account][user] = gputotau[account][user]+gpu*elapsedwindow
            trestotau[account][user] = trestotau[account][user]+(ptresweightcpu[partition]*float(cpu)+ptresweightmem[partition]*mem+ptresweightgpu[partition]*float(gpu))*float(elapsedwindow)
          except:
            cputotau[account][user] = cpu*elapsedwindow
            memtotau[account][user] = mem*elapsedwindow
            gputotau[account][user] = gpu*elapsedwindow
            trestotau[account][user] = (ptresweightcpu[partition]*float(cpu)+ptresweightmem[partition]*mem+ptresweightgpu[partition]*float(gpu))*float(elapsedwindow)
        except:
          cputotau[account] = {user: cpu*elapsedwindow}
          memtotau[account] = {user: mem*elapsedwindow}
          gputotau[account] = {user: gpu*elapsedwindow}
          trestotau[account] = {user: (ptresweightcpu[partition]*float(cpu)+ptresweightmem[partition]*mem+ptresweightgpu[partition]*float(gpu))*float(elapsedwindow)}

  # Compute Sums And Output Data
  if inuser != None:
    # Sum up all jobs over all accounts for this user
    print(f"Window Start: {instarttime} Window End: {inendtime} Total Hours: {hourrange:.2f}")
    print(f"Account User CPU-Hours Mem-Hours(GB) GPU-Hours TRES-Hours")
    for a in al:
      cputot = cputot + cputotau[a][inuser]
      memtot = memtot + memtotau[a][inuser]
      gputot = gputot + gputotau[a][inuser]
      trestot = trestot + trestotau[a][inuser]
      print(f"{a} {inuser} {cputotau[a][inuser]:.2f} {memtotau[a][inuser]:.2f} {gputotau[a][inuser]:.2f} {trestotau[a][inuser]:.2f}")

    print(f"Total: {inuser} {cputot:.2f} {memtot:.2f} {gputot:.2f} {trestot:.2f}")


# Code starts here.
if __name__ == "__main__":

  desc = (
  """
  stotal
  https://github.com/fasrc/stotal
  ---------------
  stotal is will calculate the total CPU-hours, GPU-hours, and TRES-hours for a Slurm user or account.

  When passed a user or account (note that for accounts outside of what the user is a member of that user must be either an Operator or Administrator), this
  command calculates the total usage for that user or account over the period specified. Time arguments for starttime and endtime are
  the same as the sacct command.

  -----------------
  """
  )

  parser = argparse.ArgumentParser(
    formatter_class=argparse.RawDescriptionHelpFormatter,
    description=desc,
  )
  parser.add_argument("-u", "--user", action="store", dest="user")
  parser.add_argument("-A", "--account", action="store", dest="account")
  parser.add_argument("-S", "--starttime", action="store", dest="starttime")
  parser.add_argument("-E", "--endtime", action="store", dest="endtime")
  args = parser.parse_args(args=None if sys.argv[1:] else ['--help'])

  calc_usage(args.user, args.account, args.starttime, args.endtime)
